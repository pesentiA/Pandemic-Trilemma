df.residual(fe_hc)
# HC1 SE manuell aus HC0
NT <- nobs(fe_hc)
K <- length(coef(fe_hc))  # Anzahl geschätzte Koeffizienten im Within-Modell
se_hc0 <- ct0["mtr_pct_wlth_top", "Std. Error"]
se_hc1_manual <- se_hc0 * sqrt(NT / (NT - K))
