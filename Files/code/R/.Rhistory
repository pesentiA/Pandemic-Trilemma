##Problem der Finanzierung
# Wie viel Volumen ist EU-finanziert?
fm1 %>%
filter(transmission_channel %in% c("CP", "DI")) %>%
group_by(transmission_channel, is_eu) %>%
summarise(
n = n(),
total_vol = sum(size_pct, na.rm = TRUE),
.groups = "drop"
)
# Aggregiere ohne EU-Maßnahmen
fiscal_noEU <- fm1 %>%
filter(broad_fiscal %in% c(1, 2), is_eu == 0) %>%
group_by(Country, YQ) %>%
summarise(
F_CP_noEU = sum(size_pct[transmission_channel == "CP"], na.rm = TRUE),
F_DI_noEU = sum(size_pct[transmission_channel == "DI"], na.rm = TRUE),
.groups = "drop"
) %>%
rename(Quarter = YQ)
# Merge und schätze
pdataD <- pdataD %>%
left_join(fiscal_noEU, by = c("Country", "Quarter")) %>%
mutate(
F_CP_noEU = replace_na(F_CP_noEU, 0),
F_DI_noEU = replace_na(F_DI_noEU, 0)
)
m_d_noEU <- plm(
debt_dR ~ y_t_pct + F_CP_noEU + F_DI_noEU + as.numeric(Quarter),
data = pdataD, model = "within", effect = "individual"
)
coeftest(m_d_noEU, vcov = vcovHC(m_d_noEU, cluster = "group", type = "HC1"))
m_d_noEU <- plm(
debt_dN ~ y_t_pct + F_CP_noEU + F_DI_noEU + as.numeric(Quarter),
data = pdataD, model = "within", effect = "individual"
)
coeftest(m_d_noEU, vcov = vcovHC(m_d_noEU, cluster = "group", type = "HC1"))
m_d_noEU <- plm(
debt_dR ~ y_t_pct + F_CP_above + F_DI_noEU + as.numeric(Quarter),
data = pdataD, model = "within", effect = "individual"
)
coeftest(m_d_noEU, vcov = vcovHC(m_d_noEU, cluster = "group", type = "HC1"))
m_d_noEU <- plm(
debt_dR ~ y_t_pct + F_CP_above + F_CP_below + F_DI_noEU + as.numeric(Quarter),
data = pdataD, model = "within", effect = "individual"
)
coeftest(m_d_noEU, vcov = vcovHC(m_d_noEU, cluster = "group", type = "HC1"))
coeftest(m_d_noEU, vcov = vcovHC(m_d_noEU, cluster = "group", type = "HC3"))
coeftest(m_d_noEU, vcov = vcovHC(m_d_noEU, cluster = "group", type = "HC1"))
# Eurozone vs. Nicht-Euro
pdataY$euro <- as.numeric(pdataY$Country %in%
c("AUT", "BEL", "EST", "FIN", "FRA", "DEU", "GRC", "IRL",
"ITA", "LVA", "LTU", "LUX", "NLD", "PRT", "SVK", "SVN", "ESP"))
m_y_euro <- plm(
y_t_pct ~ S_mean_tw * y_lag1 + S_mean_tw * F_CP + F_DI_lag2 +
euro:F_CP + euro:F_DI_lag2,
data = pdataY, model = "within", effect = "twoways"
)
