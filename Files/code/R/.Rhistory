m_y_euro <- plm(
y_t_pct ~ S_mean_tw * y_lag1 + S_mean_tw * F_CP + S_mean_tw*F_DI_lag2 +
euro:F_CP + euro:F_DI_lag2,
data = pdataY, model = "within", effect = "twoways"
)
