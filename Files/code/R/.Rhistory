pdata_panel$S_country_mean    <- ave(pdata_panel$S_mean_tw, pdata_panel$Country)
pdata_panel$F_CP_country_mean <- ave(pdata_panel$F_CP_lag2, pdata_panel$Country)
pdata_panel
pdataY$S_country_mean    <- ave(pdataY$S_mean_tw, pdataY$Country)
pdataY$F_CP_country_mean <- ave(pdataY$F_CP_lag2, pdataY$Country)
pdataY$F_DI_country_mean <- ave(pdataY$F_DI_lag2, pdataY$Country)
m_mundlak <- plm(
y_t_pct ~ S_mean_tw + F_CP_lag2 + F_DI_lag2
+ S_country_mean + F_CP_country_mean + F_DI_country_mean
+ p_proj_all_ages,
data  = pdataY,
model = "pooling"
)
summary(m_mundlak)
df_cross <- pdataY %>%
filter(t_idx >= 5, t_idx <= 14) %>%
group_by(Country) %>%
summarise(
y_avg     = mean(y_t_pct,       na.rm = TRUE),
debt_cum  = sum(debt_dR,         na.rm = TRUE),
S_avg     = mean(S_mean_tw,     na.rm = TRUE),
F_CP_cum  = sum(F_CP,           na.rm = TRUE),
F_DI_cum  = sum(F_DI,           na.rm = TRUE),
d_avg     = mean(p_proj_all_ages,       na.rm = TRUE)
)
m_cross <- lm(y_avg ~ S_avg + F_CP_cum + F_DI_cum + d_avg, data = df_cross)
summary(m_cross)
