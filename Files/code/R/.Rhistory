total_below = sum(F_CP_below_adj_mid, na.rm = TRUE),
mean_y      = mean(y_t_pct, na.rm = TRUE),
total_debt  = sum(debt_dR, na.rm = TRUE),
.groups     = "drop"
)
# Plot 1: S vs. Total Spending
p1 <- ggplot(country_agg, aes(x = mean_S, y = total_F)) +
