F_CP_below_adj_lag2   = lag(F_CP_below_adj_lo, 2),
# Three-way decomposition (above/loans/guarantees)
F_CP_loans_lag2       = lag((F_CP_loans*0.35), 2),
F_CP_guar_adj_lag2    = lag(F_CP_guar_adj, 2)
) %>%
ungroup()
