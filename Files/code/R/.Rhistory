# LSDV = lm mit expliziten Kanton- und Jahr-Dummies
lsdv <- lm(log(sum_wlth_total) ~ mtr_pct_wlth_top + factor(canton) + factor(year),
data = swisswealth)
# Block-Bootstrap SE (geclustert nach Kanton)
set.seed(1234)
ct_bs <- coeftest(lsdv, vcov = vcovBS(lsdv, cluster = ~canton, R = 9999))
ct_bs["mtr_pct_wlth_top", ]
#own function
set.seed(1234)
B <- 9999
# Originales Modell und t-Statistik
lsdv <- lm(log(sum_wlth_total) ~ mtr_pct_wlth_top + factor(canton) + factor(year),
data = swisswealth)
ct_orig <- coeftest(lsdv, vcov = vcovHC(lsdv, type = "HC1"))
t_orig <- ct_orig["mtr_pct_wlth_top", "t value"]
# Restringiertes Modell unter H0: beta = 0
lsdv_h0 <- lm(log(sum_wlth_total) ~ factor(canton) + factor(year),
data = swisswealth)
resid_h0 <- residuals(lsdv_h0)
fitted_h0 <- fitted(lsdv_h0)
# Kanton-IDs für Clustering
cantons <- swisswealth$canton[complete.cases(swisswealth[, c("sum_wlth_total", "mtr_pct_wlth_top")])]
unique_cantons <- unique(cantons)
N <- length(unique_cantons)
# Bootstrap-Loop
t_boot <- numeric(B)
for (b in 1:B) {
# Rademacher-Gewichte: +1 oder -1 pro Kanton
weights <- sample(c(-1, 1), N, replace = TRUE)
names(weights) <- unique_cantons
# Neue Residuen: Vorzeichen flippen pro Kanton
resid_star <- resid_h0 * weights[cantons]
# Neues y* unter H0
y_star <- fitted_h0 + resid_star
# Schätze volles Modell mit y*
data_boot <- swisswealth[complete.cases(swisswealth[, c("sum_wlth_total", "mtr_pct_wlth_top")]), ]
data_boot$y_star <- y_star
lsdv_boot <- lm(y_star ~ mtr_pct_wlth_top + factor(canton) + factor(year),
data = data_boot)
ct_boot <- coeftest(lsdv_boot, vcov = vcovHC(lsdv_boot, type = "HC1"))
t_boot[b] <- ct_boot["mtr_pct_wlth_top", "t value"]
}
# p-Wert: Anteil der Bootstrap-t-Statistiken extremer als Original
p_wild <- mean(abs(t_boot) >= abs(t_orig))
cat("Original t-stat:", t_orig, "\n")
cat("Wild cluster bootstrap p-value:", p_wild, "\n")
##use fwildclusterboot-> directly from github
library(fwildclusterboot)
wild <- boottest(lsdv,
param = "mtr_pct_wlth_top",
clustid = c("canton"),
B = 9999,
type = "rademacher",
impose_null = TRUE,
p_val_type = "two-tailed")
summary(wild)
cat("HC0 t(294):", ct0["mtr_pct_wlth_top", 4], "\n")
cat("HC1 t(294):", ct1["mtr_pct_wlth_top", 4], "\n")
cat("HC3 t(294):", ct3["mtr_pct_wlth_top", 4], "\n")
cat("Block Bootstrap t(294):", ct_bs["mtr_pct_wlth_top", 4], "\n")
cat("Wild Cluster Bootstrap:", p_wild, "\n")
