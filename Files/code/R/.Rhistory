##Functional Form
#Non linearity
m_quad <- plm(
y_t_pct ~ S_mean_tw * y_lag1 + S_mean_tw * F_CP + I(F_CP^2) + F_DI_lag2,
data = pdataY, model = "within", effect = "twoways"
)
coeftest(m_quad, vcov = vcovHC(m_quad, cluster = "group", type = "HC1"))
##Knapp nicht signifikant, negativ-> macht sinn, abnehmender Grenznutzen-> Interaktionsterm absoribiert nicht-linearitÃ¤t
##Rechtsschiefe von CP ist durch Interaktion mit S teilweise kontrolliert-> Log wÃ¤re iene LÃ¶sung aber viele 0-> Extreme Massnahmen hatten auch massives S-> das hilft
##Additive SeparabilitÃ¤t
pdataY$S_high <- as.numeric(pdataY$S_mean_tw < 50)
m_threshold <- plm(
y_t_pct ~ S_mean_tw * y_lag1 + F_CP * S_high + F_DI_lag2,
data = pdataY, model = "within", effect = "twoways"
)
coeftest(m_threshold, vcov = vcovHC(m_threshold, cluster = "group", type = "HC1"))
##STandardfehler
