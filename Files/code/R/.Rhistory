m_y_euro <- plm(
y_t_pct ~ S_mean_tw * y_lag1 + S_mean_tw * F_CP + S_lag1*F_DI_lag2,
data = pdataY, model = "within", effect = "twoways"
)
coeftest(m_y_euro, vcov = vcovHC(m_y_euro, cluster = "group", type = "HC1"))
m_y_euro <- plm(
